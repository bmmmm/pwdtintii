#!/usr/bin/env bash
# pwdtintii — CLI companion to the shell plugin.
# Invoked by the plugin via its absolute path; the `pwdtintii` shell function
# shadows this binary on PATH, so interactively you drive it through `pt`.
# Subcommands:
#   view                    Merged list+preview browser (fzf; ctrl-t cycles
#                           swatch/contrast × dark/light)
#   preview-family <fam>    Colored swatches for a family (stdout, fzf --preview)
#   preview-contrast <fam>  Swatches + WCAG/APCA scores per shade (fzf --preview)
#   emit-family <fam>       Emit OSC 11 to /dev/tty (live focus preview)
#   actions                 Action catalog driving the `pt` hub menu
#   describe-action <name>  One action's description (for the hub preview pane)
#   list                    Print all families
#   palette                 Print the loaded palette path
#   palette-for <theme>     Print the bundled palette path for dark|light
#
# Resolves the palette from PWDTINTII_PALETTE or ../palettes/default.tsv relative to this script.

set -euo pipefail

SELF_DIR="$(cd "$(dirname "$0")" && pwd)"
PALETTE="${PWDTINTII_PALETTE:-${SELF_DIR}/../palettes/default.tsv}"

# Help works without a palette (it's what you read when things are misconfigured):
# print the header doc block (lines 2..first blank) and stop before the code.
case "${1:-}" in
  -h|--help|help|"") sed -n '2,/^$/p' "$0"; exit 0 ;;
esac

if [[ ! -f "$PALETTE" ]]; then
  echo "pwdtintii: palette not found: $PALETTE" >&2
  exit 1
fi

shades_for() {
  local want="$1"
  awk -v want="$want" -F'\t' '$1 == want { print $2, $3, $4, $5; exit }' "$PALETTE"
}

hex_to_rgb() {
  local hex="${1#\#}"
  printf '%d %d %d\n' "0x${hex:0:2}" "0x${hex:2:2}" "0x${hex:4:2}"
}

# Integer YIQ perceived luminance of an r,g,b triple (0-255 each) → _PT_LUM.
# >= 128 reads as a light color. A function — one weight set, one threshold, in
# one place — returning via a global so it stays fork-free on the picker's
# per-keystroke focus path (the formula used to be inlined in two helpers).
_pt_lum() {
  _PT_LUM=$(( ($1 * 299 + $2 * 587 + $3 * 114) / 1000 ))
}

# True when arg is a #rrggbb / rrggbb hex — the only form the math helpers parse.
# Guards the 16# arithmetic from crashing on a malformed palette cell under set -e.
_pt_valid_hex() {
  [[ "${1#\#}" =~ ^[0-9a-fA-F]{6}$ ]]
}

# A full-width row painted solid in the shade color.
_pt_fill_row() {
  printf '\e[48;2;%s;%s;%sm%*s\e[0m\n' "$1" "$2" "$3" "$4" ''
}

# Readable foreground tones for text painted on a band of color (r,g,b). Sets
# _PT_FG to "ghost_r ghost_g ghost_b  label_r label_g label_b": a muted tone for
# the ghost-text sample (it gauges dim-autosuggestion readability, so it stays
# dim — just dark-on-light instead of light-on-dark) and a strong tone for the
# label. _pt_lum picks the band: >= 128 is a light band → flip to dark text.
# The shipped palettes split cleanly (dark tops at lum 113, light bottoms at
# 164); being per-band, this also covers a stray light shade in a dark palette.
_pt_text_fg() {
  _pt_lum "$1" "$2" "$3"
  if (( _PT_LUM >= 128 )); then
    _PT_FG="72 72 72 16 16 16"          # light band: dim-dark ghost + near-black label
  else
    _PT_FG="220 220 220 235 235 235"    # dark band: dim-light ghost + near-white label
  fi
}

# A band's middle row: ghost italic "sample ghost text" on the left (so you can
# judge autosuggestion readability on the shade), the shadeN + hex label on the
# right, padded with the shade color across the full pane width. Both text tones
# track the band's luminance (see _pt_text_fg) so they stay legible on a pale
# light-palette shade, not only on the dark default.
_pt_text_row() {
  local r="$1" g="$2" b="$3" w="$4" label="$5" hex="$6"
  local left=" sample ghost text" right="${label}  ${hex} "
  if (( ${#left} + ${#right} + 1 > w )); then
    left=""   # pane too narrow for the sample text — keep just the label
  fi
  local pad=$(( w - ${#left} - ${#right} ))
  if (( pad < 0 )); then pad=0; fi
  local gr gg gb lr lg lb
  _pt_text_fg "$r" "$g" "$b"
  read -r gr gg gb lr lg lb <<< "$_PT_FG"
  printf '\e[48;2;%s;%s;%sm\e[38;2;%s;%s;%sm\e[3m%s\e[23m%*s\e[1;38;2;%s;%s;%sm%s\e[0m\n' \
    "$r" "$g" "$b" "$gr" "$gg" "$gb" "$left" "$pad" '' "$lr" "$lg" "$lb" "$right"
}

# Distribute n color bands across an FZF_PREVIEW_LINES-tall pane: fill _PT_BANDS
# with each band's row count (summing to the rows below the 2-line header) and
# set _PT_GAP=1 when there's room for a blank line between bands. Shared by the
# swatch (preview-family) and contrast (preview-contrast) previews so the two
# stay vertically in step.
_pt_band_heights() {
  local n="$1" H="$2"
  local avail=$(( H - 2 ))
  if (( avail < n )); then avail=$n; fi
  _PT_GAP=0
  if (( avail >= n * 4 + (n - 1) )); then _PT_GAP=1; fi
  local band_space=$(( avail - _PT_GAP * (n - 1) ))
  local base=$(( band_space / n ))
  local extra=$(( band_space % n ))
  if (( base < 1 )); then base=1; fi
  _PT_BANDS=()
  local idx bh
  for (( idx = 0; idx < n; idx++ )); do
    bh=$base
    if (( idx < extra )); then bh=$(( bh + 1 )); fi
    _PT_BANDS+=( "$bh" )
  done
}

# The active palette's theme name for the preview banner: dark/light for the
# bundled palettes, empty for a custom one (nothing dark/light to label).
_pt_theme_label() {
  local d l; d="$(cmd_palette_for dark)"; l="$(cmd_palette_for light)"
  if   [[ "$PALETTE" -ef "$d" ]]; then printf 'dark'
  elif [[ "$PALETTE" -ef "$l" ]]; then printf 'light'
  fi
}

# The preview pane's top line: "<mode>[ · <theme>] · <family>", mode+theme bold.
# This is the single place the viewer shows which of the cycle's states is live,
# so the ctrl-t change happens here (right pane) and nowhere else — the fzf
# header on the left stays static.
_pt_preview_banner() {
  local mode="$1" fam="$2" theme; theme="$(_pt_theme_label)"
  if [[ -n "$theme" ]]; then
    printf '\e[1m%s · %s\e[0m · %s\n\n' "$mode" "$theme" "$fam"
  else
    printf '\e[1m%s\e[0m · %s\n\n' "$mode" "$fam"
  fi
}

cmd_preview_family() {
  local fam="$1"
  local shades; shades=$(shades_for "$fam")
  if [[ -z "$shades" ]]; then
    echo "unknown family: $fam"
    return 1
  fi

  # fzf exports the preview-pane geometry; fall back to the terminal size (or a
  # sane default) when run standalone. Stretching the bands to FZF_PREVIEW_LINES
  # fills the pane top-to-bottom — no scrollbar, no empty lower half.
  local H="${FZF_PREVIEW_LINES:-${LINES:-24}}"
  local W="${FZF_PREVIEW_COLUMNS:-${COLUMNS:-44}}"
  if (( W < 12 )); then W=12; fi

  local -a hexes
  read -r -a hexes <<<"$shades" || true
  local n=${#hexes[@]}
  if (( n == 0 )); then return 0; fi
  # A custom palette reaches the CLI unvalidated (only the plugin loader checks);
  # a malformed cell would crash hex_to_rgb's printf below, so reject it loudly.
  local h
  for h in "${hexes[@]}"; do
    if ! _pt_valid_hex "$h"; then
      echo "pwdtintii: family '$fam' has a malformed shade: $h" >&2
      return 1
    fi
  done

  _pt_preview_banner swatch "$fam"

  _pt_band_heights "$n" "$H"
  local idx
  for (( idx = 0; idx < n; idx++ )); do
    local hex="${hexes[idx]}"
    local r g b
    read -r r g b < <(hex_to_rgb "$hex")
    local band_h="${_PT_BANDS[idx]}"
    local mid=$(( band_h / 2 ))
    local row
    for (( row = 0; row < band_h; row++ )); do
      if (( row == mid )); then
        _pt_text_row "$r" "$g" "$b" "$W" "shade${idx}" "$hex"
      else
        _pt_fill_row "$r" "$g" "$b" "$W"
      fi
    done
    if (( _PT_GAP == 1 && idx < n - 1 )); then echo; fi
  done
}

# ── Contrast preview: colored swatches annotated with readability scores ──────
# Badge a WCAG ratio (passed as a centi-int: 9.52 -> 952) and an APCA Lc
# magnitude (deci-int: 73.9 -> 739) into the standard tiers. Integer args keep
# the focus path fork-free — no awk/bc per row.
_pt_wcag_badge() {
  if   (( $1 >= 450 )); then printf 'AA'
  elif (( $1 >= 300 )); then printf 'AA-large'
  else                       printf 'fail'
  fi
}
_pt_apca_badge() {
  if   (( $1 >= 750 )); then printf 'body'
  elif (( $1 >= 600 )); then printf 'large'
  elif (( $1 >= 450 )); then printf 'min'
  else                       printf 'low'
  fi
}

# A contrast band's middle row: the shade label, its WCAG ratio and APCA Lc
# (against the theme's standard text), painted in that shade's best-readable
# foreground — the tone contrast.py recommends — on the shade itself. So you
# read the scores in the very color the engine picked as most legible here.
# Compacts the layout in two steps when the pane is too narrow for the full line.
_pt_contrast_row() {
  local r="$1" g="$2" b="$3" w="$4" label="$5" hex="$6" \
        wcag="$7" wb="$8" lc="$9" ab="${10}" fgr="${11}" fgg="${12}" fgb="${13}"
  local text=" ${label}  ${hex}  WCAG ${wcag} ${wb}  APCA ${lc} ${ab} "
  if (( ${#text} > w )); then text=" ${label}  W ${wcag} ${wb}  A ${lc} ${ab} "; fi
  if (( ${#text} > w )); then text=" ${label} ${wb}/${ab} "; fi
  local pad=$(( w - ${#text} ))
  if (( pad < 0 )); then pad=0; fi
  printf '\e[48;2;%s;%s;%sm\e[1;38;2;%s;%s;%sm%s%*s\e[0m\n' \
    "$r" "$g" "$b" "$fgr" "$fgg" "$fgb" "$text" "$pad" ''
}

# preview-contrast <family>: like preview-family, but each band carries its
# readability scores. Parses contrast.py --row (the one source of the math), so
# the colored viewer and the text dump can never disagree. Theme is auto (the
# palette's mean luminance) — the bundled dark/light palettes classify the way
# the viewer's dark/light cycle intends.
cmd_preview_contrast() {
  local fam="$1"
  command -v python3 >/dev/null 2>&1 || { echo "pwdtintii: pt contrast needs python3"; return 1; }
  local rows; rows=$(python3 "${SELF_DIR}/../scripts/contrast.py" "$PALETTE" auto --row "$fam") || return 1
  if [[ -z "$rows" ]]; then
    echo "unknown family: $fam"
    return 1
  fi

  local H="${FZF_PREVIEW_LINES:-${LINES:-24}}"
  local W="${FZF_PREVIEW_COLUMNS:-${COLUMNS:-44}}"
  if (( W < 12 )); then W=12; fi

  # Parse all rows first so the band count is known before height distribution.
  local -a idxs hexes wcags lcs bfgs
  local i hex wcag lc bfg
  while IFS=$'\t' read -r i hex wcag lc bfg; do
    [[ -z "$i" ]] && continue
    idxs+=( "$i" ); hexes+=( "$hex" ); wcags+=( "$wcag" ); lcs+=( "$lc" ); bfgs+=( "$bfg" )
  done <<< "$rows"
  local n=${#hexes[@]}
  if (( n == 0 )); then return 0; fi

  _pt_preview_banner contrast "$fam"
  _pt_band_heights "$n" "$H"

  local k
  for (( k = 0; k < n; k++ )); do
    local r g b fgr fgg fgb
    read -r r g b < <(hex_to_rgb "${hexes[k]}")
    read -r fgr fgg fgb < <(hex_to_rgb "${bfgs[k]}")
    local wcag_centi="${wcags[k]/./}" lc_mag="${lcs[k]#[-+]}"
    local lc_deci="${lc_mag/./}"
    local wb ab
    wb=$(_pt_wcag_badge "$wcag_centi")
    ab=$(_pt_apca_badge "$lc_deci")
    local band_h="${_PT_BANDS[k]}"
    local mid=$(( band_h / 2 ))
    local row
    for (( row = 0; row < band_h; row++ )); do
      if (( row == mid )); then
        _pt_contrast_row "$r" "$g" "$b" "$W" "shade${idxs[k]}" "${hexes[k]}" \
          "${wcags[k]}" "$wb" "${lcs[k]}" "$ab" "$fgr" "$fgg" "$fgb"
      else
        _pt_fill_row "$r" "$g" "$b" "$W"
      fi
    done
    if (( _PT_GAP == 1 && k < n - 1 )); then echo; fi
  done
}

# Darken a #rrggbb hex toward black by PCT percent (50 = half brightness).
_pt_dim_hex() {
  local hex="${1#\#}" pct="$2"
  local r=$(( 16#${hex:0:2} * pct / 100 ))
  local g=$(( 16#${hex:2:2} * pct / 100 ))
  local b=$(( 16#${hex:4:2} * pct / 100 ))
  printf '#%02x%02x%02x\n' "$r" "$g" "$b"
}

# Lighten a #rrggbb hex toward white by PCT percent (50 = halfway to white).
# The mirror of _pt_dim_hex, for light palettes.
_pt_lift_hex() {
  local hex="${1#\#}" pct="$2"
  local r=$(( 16#${hex:0:2} )) g=$(( 16#${hex:2:2} )) b=$(( 16#${hex:4:2} ))
  r=$(( r + (255 - r) * pct / 100 ))
  g=$(( g + (255 - g) * pct / 100 ))
  b=$(( b + (255 - b) * pct / 100 ))
  printf '#%02x%02x%02x\n' "$r" "$g" "$b"
}

# True when a #rrggbb hex reads as a light color (perceived luminance, integer
# YIQ, >= 128) — picks the focus-tone direction per palette.
_pt_is_light_hex() {
  local hex="${1#\#}"
  _pt_lum "$(( 16#${hex:0:2} ))" "$(( 16#${hex:2:2} ))" "$(( 16#${hex:4:2} ))"
  (( _PT_LUM >= 128 ))
}

# The live-preview focus background for a family: a tone nudged just past the
# family's shade range so all four swatches stand out in the preview pane while
# the terminal still tints toward the family. A dark palette dims the darkest
# shade toward black (sits below all four). A light palette — pale shades, and
# usually a light terminal theme with dark text that a darkened background would
# render unreadable — lifts the lightest shade toward white instead (sits above
# all four, and keeps that dark text legible).
_pt_focus_tone() {
  local shades; shades=$(shades_for "$1")
  [[ -z "$shades" ]] && return 1
  # Darkest + lightest by luminance, not by position — so a palette that orders
  # its shades light-to-dark still classifies correctly (and a malformed cell
  # bails cleanly instead of crashing the 16# arithmetic under set -e).
  local sh dark="" light="" dlum=256 llum=-1 h
  for sh in $shades; do
    _pt_valid_hex "$sh" || return 1
    h="${sh#\#}"
    _pt_lum "$(( 16#${h:0:2} ))" "$(( 16#${h:2:2} ))" "$(( 16#${h:4:2} ))"
    if (( _PT_LUM < dlum )); then dlum=$_PT_LUM; dark="$sh"; fi
    if (( _PT_LUM > llum )); then llum=$_PT_LUM; light="$sh"; fi
  done
  if _pt_is_light_hex "$dark"; then
    _pt_lift_hex "$light" 50
  else
    _pt_dim_hex "$dark" 50
  fi
}

cmd_emit_family() {
  local tone; tone=$(_pt_focus_tone "${1:-}") || return 0
  # Best-effort: a non-configured /dev/tty (no controlling terminal) must not
  # abort the picker under set -e — the group redirect swallows the failed
  # redirect's message too, which a trailing 2>/dev/null alone would not.
  { printf '\e]11;%s\a' "$tone" > /dev/tty; } 2>/dev/null || true
}

cmd_list() {
  awk -F'\t' '$1 != "" && $1 != "family" && $1 !~ /^#/ { print $1 }' "$PALETTE"
}

# Like list, but each family carries a high-contrast SGR foreground for the fzf
# menus (run with --ansi). Recomputed from PWDTINTII_PALETTE on every call, so the
# picker's ctrl-t reload reflows the list dark<->light in place: fzf re-reads
# per-line ANSI colors on a reload, where a static --color stays fixed for the
# whole session. `list` itself stays plain (scripts + the no-fzf fallback parse it).
cmd_list_menu() {
  _pt_ui_tone
  local r g b
  read -r r g b < <(hex_to_rgb "$_PT_UI_HI")
  local sgr rst
  sgr=$(printf '\033[38;2;%s;%s;%sm' "$r" "$g" "$b")
  rst=$(printf '\033[0m')
  awk -F'\t' -v sgr="$sgr" -v rst="$rst" \
    '$1 != "" && $1 != "family" && $1 !~ /^#/ { print sgr $1 rst }' "$PALETTE"
}

cmd_palette() {
  echo "$PALETTE"
}

# Resolve a bundled palette path by theme name. The viewer's dark/light cycle
# goes through here, so the two bundled locations live in one place.
cmd_palette_for() {
  case "${1:-}" in
    dark)  printf '%s\n' "${SELF_DIR}/../palettes/default.tsv" ;;
    light) printf '%s\n' "${SELF_DIR}/../palettes/light.tsv" ;;
    *) echo "pwdtintii: palette-for needs 'dark' or 'light'" >&2; return 1 ;;
  esac
}

# view-advance <statedir>: the ctrl-t step of the viewer. Reads the current cycle
# index + the state table (one "palette<TAB>preview-cmd" line per state, written
# by cmd_view), advances the index (wrapping), and prints the fzf action that
# repaints the preview pane. Only the preview changes on ctrl-t — the mode/theme
# label lives in the pane's banner (_pt_preview_banner), the left header stays
# static. change-preview swaps the command; refresh-preview then forces it to run
# now — without it fzf keeps the cached render for the current item until the next
# focus move, so the pane only updated after an arrow key. Internal: fzf calls it
# through transform(), not a user subcommand.
cmd_view_advance() {
  local sd="$1"
  local idx n line pal pcmd self
  idx=$(cat "$sd/idx" 2>/dev/null || echo 0)
  n=$(wc -l < "$sd/states")
  (( n == 0 )) && return 0
  idx=$(( (idx + 1) % n ))
  printf '%s\n' "$idx" > "$sd/idx"
  line=$(sed -n "$(( idx + 1 ))p" "$sd/states")
  IFS=$'\t' read -r pal pcmd <<< "$line"
  self="${SELF_DIR}/pwdtintii"
  printf 'change-preview(PWDTINTII_PALETTE=%s %s %s {})+refresh-preview\n' "$pal" "$self" "$pcmd"
}

# The header color: the current family's own hue, pushed in luminance until it
# reads against the tinted background. A single family's four shades sit too
# close in luminance to contrast with one of their own (steel spans ~30-75), so
# picking a raw shade leaves the header near-invisible. Instead take the family's
# extreme shade away from the background — lightest on a dark tint, darkest on a
# light one — and lift/dim it toward white/black for a legible same-family tone.
# Prints "#rrggbb", or nothing when the shell's family/shade is unknown (a direct
# CLI call), so the caller skips --color and fzf keeps its default header color.
_pt_view_header_color() {
  local fam="${PWDTINTII_VIEW_FAMILY:-}" idx="${PWDTINTII_VIEW_SHADE:-0}"
  [[ -z "$fam" ]] && return 0
  local shades; shades=$(shades_for "$fam")
  [[ -z "$shades" ]] && return 0
  local -a hexes; read -r -a hexes <<< "$shades"
  (( ${#hexes[@]} == 0 )) && return 0
  [[ "$idx" =~ ^[0-9]+$ ]] || idx=0
  (( idx >= ${#hexes[@]} )) && idx=0
  local bg="${hexes[idx]}"
  _pt_valid_hex "$bg" || return 0
  local r g b bglum
  read -r r g b < <(hex_to_rgb "$bg"); _pt_lum "$r" "$g" "$b"; bglum=$_PT_LUM
  # The family's lightest and darkest shade by luminance.
  local lightest="" darkest="" llum=-1 dlum=256 h hl
  for h in "${hexes[@]}"; do
    _pt_valid_hex "$h" || continue
    read -r r g b < <(hex_to_rgb "$h"); _pt_lum "$r" "$g" "$b"; hl=$_PT_LUM
    (( hl > llum )) && { llum=$hl; lightest="$h"; }
    (( hl < dlum )) && { dlum=$hl; darkest="$h"; }
  done
  [[ -z "$lightest" ]] && return 0
  if (( bglum < 128 )); then
    _pt_lift_hex "$lightest" 55   # dark tint → bright same-family tone
  else
    _pt_dim_hex "$darkest" 45     # light tint → deep same-family tone
  fi
}

# view: the merged list+preview browser — the old `list` + `preview` in one. An
# fzf picker over the families with a colored preview pane, and one ctrl-t that
# cycles the pane through swatch/dark, swatch/light, contrast/dark, contrast/light
# (or just swatch ↔ contrast for a custom palette with no light variant). The
# state machine lives in a temp dir that cmd_view_advance steps on each ctrl-t.
# Read-only: ENTER and ESC both close it, nothing is pinned and no OSC is emitted
# (a separate process can't restore the shell's tint, so it must not change it).
# The shell passes its current family/shade via PWDTINTII_VIEW_* for the header.
cmd_view() {
  if ! command -v fzf >/dev/null 2>&1; then
    cmd_list   # no fzf: degrade to the plain family list, like list/preview did
    return 0
  fi
  local dark light bundled=0
  dark="$(cmd_palette_for dark)"
  light="$(cmd_palette_for light)"
  if [[ -f "$dark" && -f "$light" ]] && { [[ "$PALETTE" -ef "$dark" ]] || [[ "$PALETTE" -ef "$light" ]]; }; then
    bundled=1
  fi

  # The left header is static — it no longer changes on ctrl-t (the live mode +
  # theme label lives in the preview banner now, so all cycling shows in the
  # right pane). Prefix the shell's current family/shade when the plugin passed it.
  local statichdr="ctrl-t: cycle · esc: close"
  [[ -n "${PWDTINTII_VIEW_FAMILY:-}" ]] && statichdr="${PWDTINTII_VIEW_FAMILY}/${PWDTINTII_VIEW_SHADE:-?} · ${statichdr}"

  # State table: one "palette<TAB>preview-cmd" line per cycle step. cmd_view_advance
  # steps the index on each ctrl-t; the banner inside each preview names the state.
  local sd; sd="$(mktemp -d "${TMPDIR:-/tmp}/pwdtintii-view.XXXXXX")"
  printf '0\n' > "$sd/idx"
  {
    if (( bundled )); then
      printf '%s\tpreview-family\n'   "$dark"
      printf '%s\tpreview-family\n'   "$light"
      printf '%s\tpreview-contrast\n' "$dark"
      printf '%s\tpreview-contrast\n' "$light"
    else
      printf '%s\tpreview-family\n'   "$PALETTE"
      printf '%s\tpreview-contrast\n' "$PALETTE"
    fi
  } > "$sd/states"

  local self="${SELF_DIR}/pwdtintii"
  local initpal initcmd
  IFS=$'\t' read -r initpal initcmd < <(sed -n '1p' "$sd/states")

  # High-contrast menu over the tint (see _pt_fzf_colors): light text on the dark
  # palette, dark on the light one, the family list colored per-line via --ansi.
  # The header keeps the current family's own hue (a legible same-family tone) when
  # the shell passed it, falling back to the neutral foreground otherwise.
  _pt_ui_tone
  local hcolor; hcolor=$(_pt_view_header_color)
  [[ -z "$hcolor" ]] && hcolor="$_PT_UI_HI"
  local colorspec; colorspec=$(_pt_fzf_colors "$_PT_UI_HI" "$_PT_UI_DIM" "$_PT_UI_SEL" "$hcolor")

  cmd_list_menu | fzf \
      --ansi \
      --prompt='view > ' \
      --height=100% \
      --reverse \
      --preview="PWDTINTII_PALETTE=${initpal} ${self} ${initcmd} {}" \
      --preview-window=right:55%:nowrap \
      --bind='enter:abort' \
      --bind='change:first' \
      --bind="ctrl-t:transform(${self} view-advance ${sd})" \
      --color="$colorspec" \
      --header="${statichdr}" \
      >/dev/null || true
  # Clean up inline (not via an EXIT trap): the trap fires after this function
  # returns, where `local sd` is out of scope — under set -u that aborts the
  # script with "sd: unbound variable" before rm runs, leaking the dir. fzf
  # absorbs ctrl-c itself, so control returns here either way. Mirrors the picker.
  rm -rf "$sd"
}

# ── Picker / viewer fzf chrome: high-contrast menus over the live tint ───────
# The picker (the plugin's _pwdtintii_pick_interactive) used to restart fzf on
# every ctrl-t — a full screen redraw that flickered. The helpers below let it
# keep fzf open and repaint in place instead, the same transform() technique as
# the viewer above. The plugin keeps the committed-pick + live-tint logic.
#
# Both menus sit on a background the tool tints via OSC 11 (the picker per
# keystroke, the viewer to the shell's current family), and fzf otherwise inherits
# the terminal's ANSI foreground — which has no guaranteed contrast against an
# arbitrary tint, so the list rendered dim/illegible. These helpers paint the menu
# in a tone that contrasts the tint: light text on a dark palette (its tints are
# dark), dark text on a light one.

# True when the palette's mean shade luminance reads light (>= 128) — picks the
# menu tone direction. One awk pass; off the per-keystroke focus path (only menu
# setup + the ctrl-t reload reach it).
_pt_palette_is_light() {
  local mean
  mean=$(awk -F'\t' '
    function hexval(s,    v, i, c) {
      v = 0
      for (i = 1; i <= length(s); i++) {
        c = index("0123456789abcdef", tolower(substr(s, i, 1))) - 1
        if (c < 0) c = 0
        v = v * 16 + c
      }
      return v
    }
    $1 != "" && $1 != "family" && $1 !~ /^#/ {
      for (i = 2; i <= 5; i++) {
        h = $i; sub(/^#/, "", h)
        sum += (hexval(substr(h,1,2)) * 299 + hexval(substr(h,3,2)) * 587 + hexval(substr(h,5,2)) * 114) / 1000
        n++
      }
    }
    END { if (n > 0) printf "%d", sum / n; else print 128 }
  ' "$PALETTE")
  (( mean >= 128 ))
}

# Set the menu tone for the active palette: _PT_UI_HI is the legible foreground
# and every accent (it contrasts the tint — light on a dark palette, dark on a
# light one), _PT_UI_DIM a muted HI for the match counter, _PT_UI_SEL the
# focused-row background — a block on the tint's own side that HI text still reads
# on (see _pt_fzf_colors for why it can't be an inverted pill).
_pt_ui_tone() {
  if _pt_palette_is_light; then
    _PT_UI_HI='#161a1f'; _PT_UI_DIM='#454b52'; _PT_UI_SEL='#9ba2ac'
  else
    _PT_UI_HI='#e9ecf0'; _PT_UI_DIM='#9aa3ad'; _PT_UI_SEL='#4d5563'
  fi
}

# Assemble an fzf --color value: hi=foreground and every accent (pointer, prompt,
# marker, match highlight), dim=match counter, sel=focused-row background, hdr=
# header. The focused row is a sel block under HI text, not an inverted pill:
# with --ansi the list rows carry their own HI foreground (cmd_list_menu) and fzf
# keeps that per-line color over fg+, so a HI pill (bg+=HI) would paint HI text on
# a HI background and vanish — the unreadable box. sel is a tone on the tint's own
# side that HI still reads on; fg+ is set to HI too so it holds whichever way fzf
# resolves the precedence. bg is never set and gutter is transparent, so the
# OSC-11 tint shows through; a ctrl-t reload reflows the list in place where a
# static --color cannot recolor at runtime.
_pt_fzf_colors() {
  local hi="$1" dim="$2" sel="$3" hdr="$4"
  printf 'gutter:-1,fg+:%s:bold,bg+:%s,hl:%s:underline,hl+:%s:underline,pointer:%s:bold,marker:%s:bold,prompt:%s:bold,info:%s,spinner:%s,query:%s,header:%s:bold\n' \
    "$hi" "$sel" "$hi" "$hi" "$hi" "$hi" "$hi" "$dim" "$hi" "$hi" "$hdr"
}

# fzf-theme: the picker's full --color value. The header is the same neutral
# high-contrast tone as the body — the picker tints to the *focused* family
# (changing per keystroke), so unlike the fixed-family viewer a family hue has no
# reliable contrast here. Classifies by mean luminance, so a custom palette works.
cmd_fzf_theme() {
  _pt_ui_tone
  _pt_fzf_colors "$_PT_UI_HI" "$_PT_UI_DIM" "$_PT_UI_SEL" "$_PT_UI_HI"
}

# pick-toggle <statedir>: the ctrl-t step of the picker. Flips the active group
# (dark<->light), records the new palette in the state dir (so the live-tint
# focus bind and the committed pick read the current one), and prints the fzf
# action chain that swaps the list, preview, and header in place — no restart.
cmd_pick_toggle() {
  local sd="$1"
  local grp; grp=$(cat "$sd/grp" 2>/dev/null || echo dark)
  local newgrp other newpal self
  if [[ "$grp" == dark ]]; then newgrp=light; other=dark; else newgrp=dark; other=light; fi
  newpal="$(cmd_palette_for "$newgrp")"
  printf '%s\n' "$newgrp" > "$sd/grp"
  printf '%s\n' "$newpal" > "$sd/pal"
  self="${SELF_DIR}/pwdtintii"
  local hdr="↑↓ · ENTER pin · ctrl-t: ${other} theme · ESC cancel"
  printf 'reload(PWDTINTII_PALETTE=%s %s list-menu)+change-preview(PWDTINTII_PALETTE=%s %s preview-family {})+change-header(%s)\n' \
    "$newpal" "$self" "$newpal" "$self" "$hdr"
}

# ── Action catalog for the `pt` hub menu ─────────────────────────────────────
# One row per action: machine-name <TAB> padded "name + gloss" shown in fzf.
# Single source of truth — the shell dispatcher re-runs the chosen machine name
# (field 1), so every action listed here needs a matching arm in the plugin's
# pwdtintii() dispatcher (the test suite guards that coupling).
cmd_actions() {
  printf '%s\t%-9s%s\n' \
    pick     'pick'     'pin a color family (live picker)' \
    view     'view'     'browse the palette (colored; ctrl-t cycles)' \
    list     'list'     'families + current mapping' \
    auto     'auto'     'back to directory-auto (unpin)' \
    off      'off'      'stop tinting, reset background' \
    reload   'reload'   're-read the palette from disk' \
    contrast 'contrast' 'WCAG + APCA contrast of all shades'
}

# One action's help text, shown in the hub's fzf preview pane.
cmd_describe_action() {
  case "${1:-}" in
    pick)
      printf 'pick — pin a color family\n\n'
      printf 'Opens the fzf family picker. Arrow keys preview each\n'
      printf 'family live as the terminal background (OSC 11);\n'
      printf 'ENTER pins it for this shell, ESC cancels. ctrl-t\n'
      printf 'toggles between the dark and light palette groups.\n\n'
      printf 'Direct: pt pick <family>   ·   alias: ptpick\n' ;;
    view)
      printf 'view — browse the palette\n\n'
      printf 'Opens an fzf browser over the families with a colored\n'
      printf 'preview pane. ctrl-t cycles the pane through swatch and\n'
      printf 'contrast, dark and light; ESC closes. Read-only — it\n'
      printf 'previews, it does not pin (use pick for that).\n\n'
      printf 'Direct: pt view   ·   alias: ptview\n' ;;
    list)
      printf 'list — families + current mapping\n\n'
      printf 'Shows the resolved key, family and shade for this\n'
      printf 'shell, then every family with its four shades.\n\n'
      printf 'Direct: pt list   ·   alias: ptlist\n' ;;
    auto)
      printf 'auto — back to directory-derived mode\n\n'
      printf 'Clears a pinned family so the background follows the\n'
      printf 'current directory hash again.\n\n'
      printf 'Direct: pt auto   (same as pt pick --auto)\n' ;;
    off)
      printf 'off — stop tinting\n\n'
      printf 'Resets the terminal background to its default (OSC 111)\n'
      printf 'and stops re-tinting on every prompt. Re-enable with\n'
      printf 'pt auto, pt pick, or pt reload.\n\n'
      printf 'Direct: pt off\n' ;;
    reload)
      printf 'reload — re-read the palette\n\n'
      printf 'Reloads the palette TSV (and overrides) from disk and\n'
      printf 're-applies — run it after editing the palette.\n\n'
      printf 'Direct: pt reload   ·   alias: ptreload\n' ;;
    contrast)
      printf 'contrast — WCAG + APCA contrast\n\n'
      printf 'Scores each shade against the theme text in both WCAG\n'
      printf 'ratios and APCA Lc, and flags the unreadable combos.\n\n'
      printf 'Direct: pt contrast   ·   alias: ptcontrast\n' ;;
    *)
      printf '%s\n\n(no description)\n' "${1:-}" ;;
  esac
}

cmd=${1:-}
shift || true
case "$cmd" in
  view)             cmd_view ;;
  view-advance)     cmd_view_advance "${1:-}" ;;
  fzf-theme)        cmd_fzf_theme ;;
  pick-toggle)      cmd_pick_toggle "${1:-}" ;;
  preview-family)   cmd_preview_family "${1:-}" ;;
  preview-contrast) cmd_preview_contrast "${1:-}" ;;
  emit-family)      cmd_emit_family "${1:-}" ;;
  actions)          cmd_actions ;;
  describe-action)  cmd_describe_action "${1:-}" ;;
  list)             cmd_list ;;
  list-menu)        cmd_list_menu ;;
  palette)          cmd_palette ;;
  palette-for)      cmd_palette_for "${1:-}" ;;
  *)
    echo "pwdtintii: unknown subcommand: $cmd" >&2
    exit 1
    ;;
esac
